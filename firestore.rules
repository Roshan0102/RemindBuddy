rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin credentials and configuration
    match /admin_creds/{document} {
      allow read, write: if request.auth != null;
    }

    // User-specific data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow list, update: if request.auth != null;
    }
    
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Public username lookup
    match /usernames/{username} {
      // Allow any authenticated user to read/check usernames
      // Allow unauthenticated users to 'get' specifically for login/signup checks
      allow get: if true;
      allow list: if request.auth != null;
      
      // Allow creation if the user is authenticated 
      // Ensure the UID in the document data matches the authenticated user
      allow create: if request.auth != null;
      
      // Allow updates/deletes only by the owner
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Global gold prices collection
    match /global_gold_prices/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (Admin) should write
    }

    // Gold AI insights and chit advice collections
    match /gold_ai_insights/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (Admin) should write
    }

    match /gold_chit_advice/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (Admin) should write
    }

    // Global voice assistant logs
    match /voice_assistant_logs/{logId} {
      allow create, read: if request.auth != null;
    }
  }
}
