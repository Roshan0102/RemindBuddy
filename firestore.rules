rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin credentials and configuration
    match /admin_creds/{document} {
      allow read, write: if request.auth != null;
    }

    // User-specific data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/notes/{noteId} {
      allow read, update: if request.auth != null && (request.auth.uid == userId || (resource != null && request.auth.uid in resource.data.sharedWith));
      allow create, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/checklists/{checklistId} {
      allow read, update: if request.auth != null && (request.auth.uid == userId || (resource != null && request.auth.uid in resource.data.sharedWith));
      allow create, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/checklists/{checklistId}/items/{itemId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(userId)/checklists/$(checklistId)).data.sharedWith.hasAny([request.auth.uid]));
    }

    match /users/{userId}/calendar_reminders/{reminderId} {
      allow read, update, delete: if request.auth != null && (
        request.auth.uid == userId || (
          resource != null && resource.data.scheduledByUid == request.auth.uid
        )
      );
      allow create: if request.auth != null && (
        request.auth.uid == userId || (
          exists(/databases/$(database)/documents/buddy_links/$(request.auth.uid + '_' + userId)) &&
          get(/databases/$(database)/documents/buddy_links/$(request.auth.uid + '_' + userId)).data.status == 'approved'
        )
      );
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Collection Group Rules for Collaboration
    match /{path=**}/notes/{noteId} {
      allow read, update: if request.auth != null && (
        resource != null && request.auth.uid in resource.data.sharedWith
      );
    }

    match /{path=**}/checklists/{checklistId} {
      allow read, update: if request.auth != null && (
        resource != null && request.auth.uid in resource.data.sharedWith
      );
    }

    match /{path=**}/checklists/{checklistId}/items/{itemId} {
      allow read, write: if request.auth != null && (
        get(/databases/$(database)/documents/$(path)/checklists/$(checklistId)).data.sharedWith.hasAny([request.auth.uid])
      );
    }

    // Collaboration Requests
    match /collaboration_requests/{requestId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.senderUid;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.receiverUid || request.auth.uid == resource.data.senderUid);
      allow delete: if request.auth != null && (request.auth.uid == resource.data.receiverUid || request.auth.uid == resource.data.senderUid);
    }

    // Buddy Links for Scheduling Permissions
    match /buddy_links/{linkId} {
      allow create: if request.auth != null && linkId == request.auth.uid + '_' + request.resource.data.receiverUid && request.resource.data.senderUid == request.auth.uid;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.receiverUid || request.auth.uid == resource.data.senderUid);
      allow delete: if request.auth != null && (request.auth.uid == resource.data.receiverUid || request.auth.uid == resource.data.senderUid);
    }
    
    // Public username lookup
    match /usernames/{username} {
      // Allow any authenticated user to read/check usernames
      // Allow unauthenticated users to 'get' specifically for login/signup checks
      allow get: if true;
      allow list: if request.auth != null;
      
      // Allow creation if the user is authenticated 
      // Ensure the UID in the document data matches the authenticated user
      allow create: if request.auth != null;
      
      // Allow updates/deletes only by the owner
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Global gold prices collection
    match /global_gold_prices/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (Admin) should write
    }

    // Gold AI insights and chit advice collections
    match /gold_ai_insights/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (Admin) should write
    }

    match /gold_chit_advice/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (Admin) should write
    }

    // Global voice assistant logs
    match /voice_assistant_logs/{logId} {
      allow create, read: if request.auth != null;
    }

    // Gold Chits (Chit Tracker plans)
    match /gold_chits/{planId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.sharedWith
      );
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      match /installments/{monthKey} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/gold_chits/$(planId)).data.ownerId == request.auth.uid || 
          request.auth.uid in get(/databases/$(database)/documents/gold_chits/$(planId)).data.sharedWith
        );
      }
    }
  }
}
